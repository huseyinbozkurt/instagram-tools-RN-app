<?xml version="1.0" encoding="utf-8"?>
<!--
  Splash screen logo for Instagram Tools
  Instagram-style camera icon with gradient (purple → pink → orange)
  Designed for Android SplashScreen API (288×288dp viewport)
  The OS clips this into a circle with ~160dp visible radius
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="288dp"
    android:height="288dp"
    android:viewportWidth="288"
    android:viewportHeight="288">

    <!-- ── Gradient definitions ──────────────────────────────────────────── -->

    <!-- Background pill / icon body gradient: deep purple → vivid pink -->
    <path
        android:pathData="
            M80,100
            L208,100
            A28,28 0 0 1 236,128
            L236,196
            A28,28 0 0 1 208,224
            L80,224
            A28,28 0 0 1 52,196
            L52,128
            A28,28 0 0 1 80,100 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="52"  android:startY="100"
                android:endX="236"   android:endY="224">
                <item android:offset="0.00" android:color="#833AB4"/>
                <item android:offset="0.40" android:color="#E1306C"/>
                <item android:offset="1.00" android:color="#F77737"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ── Camera body outline (white, rounded-rect) ──────────────────── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="9"
        android:strokeLineJoin="round"
        android:strokeLineCap="round"
        android:pathData="
            M84,108
            L204,108
            A20,20 0 0 1 224,128
            L224,196
            A20,20 0 0 1 204,216
            L84,216
            A20,20 0 0 1 64,196
            L64,128
            A20,20 0 0 1 84,108 Z"/>

    <!-- ── Viewfinder bump (top, centered) ──────────────────────────────── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="9"
        android:strokeLineJoin="round"
        android:strokeLineCap="round"
        android:pathData="
            M120,108
            L120,98
            A14,14 0 0 1 134,84
            L154,84
            A14,14 0 0 1 168,98
            L168,108"/>

    <!-- ── Lens — outer circle ───────────────────────────────────────────── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="9"
        android:pathData="
            M144,162
            m-30,0
            a30,30 0 1,0 60,0
            a30,30 0 1,0 -60,0"/>

    <!-- ── Lens — inner highlight circle ────────────────────────────────── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="5"
        android:strokeAlpha="0.45"
        android:pathData="
            M144,162
            m-18,0
            a18,18 0 1,0 36,0
            a18,18 0 1,0 -36,0"/>

    <!-- ── Flash / viewfinder dot (top-right corner) ─────────────────── -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="
            M202,124
            m-7,0
            a7,7 0 1,0 14,0
            a7,7 0 1,0 -14,0"/>

</vector>
